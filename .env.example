# Production (main branch) — optional; these are the defaults in code.
# NEXT_PUBLIC_SITE_URL=https://www.saltguide.co.uk
# NEXT_PUBLIC_APP_ENV=production

# Staging (staging branch) — set these in Cloudflare Pages → Preview environment variables.
NEXT_PUBLIC_SITE_URL=https://staging.saltguide.co.uk
NEXT_PUBLIC_APP_ENV=staging
